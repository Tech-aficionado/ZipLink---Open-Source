# ---------------------------------------------------------------------------
# Ziplink — environment variables
# Copy this file to `.env.local` and fill in the values.
#
# Firebase project id: ziplink-41c0a
# ---------------------------------------------------------------------------

# ---- Client (public) -------------------------------------------------------
# Exposed to the browser. Safe to be public.
# All NEXT_PUBLIC_FIREBASE_* values come from the Firebase console:
#   Project settings > General > "Your apps" > Web app (SDK config).

# App origin (main site). Local dev = localhost:3200.
# Production: https://ziplink.ash-labs.tech
NEXT_PUBLIC_BASE_URL=http://localhost:3200
NEXT_PUBLIC_SITE_URL=http://localhost:3200
# Short-link domain — used to build short URLs `${NEXT_PUBLIC_SHORT_BASE_URL}/${shortCode}`.
# Production: https://zl.ash-labs.tech  (point this domain at the same deployment)
NEXT_PUBLIC_SHORT_BASE_URL=http://localhost:3200

# Firebase Web app config.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional: Google Analytics for Firebase measurement id (e.g. G-XXXXXXXXXX).
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ---- Server (secret) -------------------------------------------------------
# firebase-admin service account credentials. NEVER expose these to the client.
# Generate a private key from Firebase console > Project settings >
# Service accounts > "Generate new private key", then copy the values from the
# downloaded JSON.

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the literal "\n" sequences from the JSON key; the server converts
# them into real newlines at runtime. Wrap the whole value in double quotes.
FIREBASE_PRIVATE_KEY=
